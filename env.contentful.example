# Copy to .env.local (not committed). Tool pages use a separate `toolPage` model in Contentful.
#
# === Production (Vercel / self-hosted) — required for /blog and CMS-backed tools ===
# If the blog is empty on the live site but works locally, the same variables are missing
# on the host. In Vercel: Project → Settings → Environment Variables, add (for Production
# and Preview as needed), then run a new deployment. Never commit the token; only set it in
# the host UI. Optional: CONTENTFUL_DELIVERY_LOCALE=en-US (default), CONTENTFUL_REVALIDATE_SECONDS=300
#
# CONTENTFUL_SPACE_ID=...
# CONTENTFUL_DELIVERY_TOKEN=...   (Delivery API, not the Management/Content Management token)
# CONTENTFUL_ENVIRONMENT=master

CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT=master

# ① Content Delivery = read site (Next.js fetches)
CONTENTFUL_DELIVERY_TOKEN=
# Optional: public https image URL for `npm run contentful:seed-blog-post` (cover+OG). Default: live logo.
# CONTENTFUL_BLOG_SEED_ASSET_URL=https://toolspotai.com/toolspotai-logo.svg
# Optional: CDA response cache in seconds. Set explicitly on any host: `0` = always fresh, `300` = 5 min.
# Default: no cache when not on Vercel; 300s on Vercel. `next start` (local) is not Vercel, so you see
# new Contentful content without waiting unless you set the line below to 300.
# CONTENTFUL_REVALIDATE_SECONDS=300

# ② Management = seed scripts (tool pages + blog content model) only
CONTENTFUL_MANAGEMENT_TOKEN=
# After env: npm run contentful:seed-tools   (tool pages)   npm run contentful:seed-blog   (blog model)   npm run contentful:seed-blog-post   (one SEO “AI tools” post)

# --- toolPage fields (separate, editor-friendly) ---
# codeKey, urlSlug, title, shortTitle, description,
# SEO: seoTitle, metaDescription, ogDescription, optional canonicalUrl, seoNoIndex,
# h1Text, intro, keywords (list), howToUseSteps (list),
# JSON: faqs, content (long sections)
