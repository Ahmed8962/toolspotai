# Optional — paste the content value from Google Search Console’s HTML tag verification.
# Build with this set so the verification meta is emitted in production.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=abc123your_token_here

# Contact form — recommended: Resend (free tier). Get an API key at https://resend.com
# Add your domain later; until then Resend allows sending from onboarding@resend.dev to your inbox.
# Restart `npm run dev` after saving .env.local
# RESEND_API_KEY=re_xxxxxxxx

# Optional fallback: Web3Forms (browser). Set “Send to” to your Gmail when creating the key.
# NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_access_key_here
